# Copy this file to .env.local and fill in the values you need.
# .env.local is git-ignored — never commit real keys.

# ── AI provider (server-side only) ────────────────────────────────────────────
# Primary — OpenRouter (free tier available). Get a key at openrouter.ai
OPENROUTER_API_KEY=
# Model used via OpenRouter
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Fallback — Anthropic direct (used only if OPENROUTER_API_KEY is empty).
# Get a key at console.anthropic.com
ANTHROPIC_API_KEY=
# Model used via Anthropic direct
ANTHROPIC_MODEL=claude-sonnet-4-5-20251001

# ── Metrics collector ─────────────────────────────────────────────────────────
# Inside the KinD cluster: http://metrics-collector:3001
# Local development:        http://localhost:3001
METRICS_COLLECTOR_URL=http://metrics-collector:3001

# ── Loki (log store) ──────────────────────────────────────────────────────────
# Fluent Bit ships production pod logs into Loki; the dashboard queries them via
# LogQL for incident RCA and the /api/logs viewer.
# Inside the KinD cluster: http://loki:3100
# Local development:        http://localhost:3100
LOKI_URL=http://loki:3100
