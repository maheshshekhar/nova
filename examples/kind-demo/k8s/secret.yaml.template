# DO NOT COMMIT THIS FILE WITH REAL VALUES
# Copy to examples/kind-demo/k8s/secret.yaml, fill in values, apply to cluster
# examples/kind-demo/k8s/secret.yaml is git-ignored

apiVersion: v1
kind: Secret
metadata:
  name: ai-keys
  namespace: nova-monitoring
type: Opaque
stringData:
  OPENROUTER_API_KEY: "YOUR_OPENROUTER_KEY_HERE"
  ANTHROPIC_API_KEY: "YOUR_ANTHROPIC_KEY_HERE"

---
apiVersion: v1
kind: Secret
metadata:
  name: ai-keys
  namespace: production
type: Opaque
stringData:
  OPENROUTER_API_KEY: "YOUR_OPENROUTER_KEY_HERE"
  ANTHROPIC_API_KEY: "YOUR_ANTHROPIC_KEY_HERE"
