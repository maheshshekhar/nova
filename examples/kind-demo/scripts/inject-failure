#!/bin/bash
set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# payment-service + load-generator run in the production namespace
NAMESPACE="production"

# Run from the project root so relative paths (load-generator/Dockerfile) resolve
# regardless of the caller's working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
cd "$PROJECT_ROOT"

echo ""
echo -e "${RED}╔════════════════════════════════════════╗${NC}"
echo -e "${RED}║   INJECTING FAILURE                    ║${NC}"
echo -e "${RED}║   payment-service cascade              ║${NC}"
echo -e "${RED}╚════════════════════════════════════════╝${NC}"
echo ""

echo -e "${CYAN}[1/3]${NC} Building and loading k6 load generator..."

docker build \
  --platform linux/arm64 \
  -t nova/load-generator:latest \
  -f examples/kind-demo/load-generator/Dockerfile \
  examples/kind-demo/load-generator/

kind load docker-image nova/load-generator:latest \
  --name nova-platform

# Clean up any previous load-generator job so the script is re-runnable
kubectl delete job load-generator -n "${NAMESPACE}" --ignore-not-found 2>/dev/null || true
sleep 2

echo -e "${CYAN}[2/3]${NC} Launching load generator as Kubernetes Job..."

kubectl apply -f - <<EOF
apiVersion: batch/v1
kind: Job
metadata:
  name: load-generator
  namespace: ${NAMESPACE}
spec:
  template:
    metadata:
      labels:
        app: load-generator
    spec:
      restartPolicy: Never
      containers:
        - name: k6
          image: nova/load-generator:latest
          imagePullPolicy: Never
          env:
            - name: TARGET_URL
              value: "http://payment-service/api/checkout"
EOF

echo -e "${CYAN}[3/3]${NC} Load generator running — hammering payment-service..."
echo ""
echo -e "${YELLOW}Dashboard:${NC} http://localhost:3000/overview"
echo -e "${YELLOW}payment-service will degrade within 20-30 seconds${NC}"
echo -e "${YELLOW}transaction-service (downstream ledger) will follow — it auto-recovers once payment-service is restored${NC}"
echo ""
echo -e "${CYAN}Streaming payment-service logs (Ctrl+C to stop):${NC}"
echo ""

sleep 8

kubectl logs \
  -n "${NAMESPACE}" \
  -l app=payment-service \
  --all-containers \
  --follow \
  --tail=20 \
  --prefix
