#!/bin/bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# config-service runs in the production namespace.
NAMESPACE="production"
SERVICE="config-service"
DASHBOARD_URL="${DASHBOARD_URL:-http://localhost:3000}"

echo ""
echo -e "${RED}╔════════════════════════════════════════╗${NC}"
echo -e "${RED}║   INJECTING FAILURE                    ║${NC}"
echo -e "${RED}║   config-service — CrashLoopBackOff    ║${NC}"
echo -e "${RED}╚════════════════════════════════════════╝${NC}"
echo ""

# Rotate through the config-source kinds on repeated runs so Nova shows a
# missing env var, then a missing Secret, then a missing ConfigMap key.
ROTATION_FILE="${TMPDIR:-/tmp}/nova-config-failure-rotation"
IDX=0
[ -f "${ROTATION_FILE}" ] && IDX=$(cat "${ROTATION_FILE}" 2>/dev/null || echo 0)
VARIANT=$(( IDX % 3 ))
echo $(( IDX + 1 )) > "${ROTATION_FILE}"

case "${VARIANT}" in
  0)
    KEY="FEATURE_FLAGS_URL"; KIND="environment variable"
    SOURCE="deployment env var FEATURE_FLAGS_URL"; FTYPE="config-missing"
    ;;
  1)
    KEY="CONFIG_SIGNING_KEY"; KIND="Secret"
    SOURCE="Secret 'config-service-secrets' (key CONFIG_SIGNING_KEY)"; FTYPE="secret-missing"
    ;;
  *)
    KEY="APP_SETTINGS_JSON"; KIND="ConfigMap key"
    SOURCE="ConfigMap 'config-service-config' (key APP_SETTINGS_JSON)"; FTYPE="config-missing"
    ;;
esac

echo -e "${YELLOW}Missing config this run:${NC} ${KIND} — ${KEY}"
echo -e "${YELLOW}Source of truth:${NC}        ${SOURCE}"
echo ""

echo -e "${CYAN}[1/2]${NC} Breaking ${SERVICE} config (removing ${KIND} ${KEY}, enabling crash flag)..."
# Mark the key as required-with-no-fallback and remove it so the container fails
# config validation on boot → CrashLoopBackOff.
kubectl set env "deployment/${SERVICE}" -n "${NAMESPACE}" \
  CRASH_ON_MISSING_CONFIG=true "REQUIRED_CONFIG_KEY=${KEY}" "${KEY}-"

echo -e "${CYAN}[2/2]${NC} Recording the incident on the dashboard..."
STARTED=$(( $(date +%s) * 1000 ))
TITLE="config-service boot failure — missing ${KIND} ${KEY}"
DESCRIPTION="config-service pods are in CrashLoopBackOff after a deploy left the required ${KIND} '${KEY}' (${SOURCE}) unset. The container fails config validation on boot and never becomes Ready. Restore ${KEY} from its source of truth and roll the deployment to recover."
curl -s -X POST "${DASHBOARD_URL}/api/incidents" \
  -H "Content-Type: application/json" \
  -d "{
    \"title\": \"${TITLE}\",
    \"service\": \"config-service\",
    \"severity\": \"high\",
    \"status\": \"investigating\",
    \"failureType\": \"${FTYPE}\",
    \"startedAt\": ${STARTED},
    \"affectedUsers\": 0,
    \"description\": \"${DESCRIPTION}\"
  }" >/dev/null && echo -e "${GREEN}[OK]${NC} Incident recorded" \
  || echo -e "${YELLOW}[WARN]${NC} Could not reach dashboard at ${DASHBOARD_URL} — is the port-forward up?"

echo ""
echo -e "${YELLOW}config-service pods will enter CrashLoopBackOff shortly.${NC}"
echo -e "Open the incident on the dashboard, then click ${GREEN}Approve & Run${NC} on the"
echo -e "matched runbook (CONFIG-RECOVERY) to restore the missing ${KIND} and roll the deployment."
echo ""
echo -e "${CYAN}Watch the pods:${NC} kubectl get pods -n ${NAMESPACE} -l app=config-service -w"
echo ""
